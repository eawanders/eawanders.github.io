---
// Primary navigation (PER-164, PER-169).
// In-page anchor links to homepage sections. A client-side IntersectionObserver
// updates aria-current as the user scrolls so the active section is highlighted.

const items = [
  { section: 'home', label: 'home' },
  { section: 'about', label: 'about' },
  { section: 'research', label: 'research' },
  { section: 'projects', label: 'projects' },
  { section: 'contact', label: 'contact' },
];
---

<nav class="nav" aria-label="Primary">
  <ul>
    {
      items.map(({ section, label }) => (
        <li>
          <a href={`#${section}`} data-section={section}>
            {label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<script>
  // Scroll-spy: mark the nav item that matches the section currently in
  // the middle of the viewport with aria-current="page". Also emits
  // Vercel Analytics custom events: `nav_click` per nav-link click and
  // `section_view` once-per-session-per-section as sections enter the
  // active band.
  const navLinks = document.querySelectorAll('.nav a[data-section]');
  const sections = document.querySelectorAll('section[id]');

  navLinks.forEach((link) => {
    link.addEventListener('click', () => {
      const section = link.getAttribute('data-section') || '';
      window.va?.('event', { name: 'nav_click', data: { section } });
    });
  });

  if ('IntersectionObserver' in window && navLinks.length && sections.length) {
    const seenSections = new Set<string>();
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              if (link.getAttribute('data-section') === id) {
                link.setAttribute('aria-current', 'page');
              } else {
                link.removeAttribute('aria-current');
              }
            });
            if (!seenSections.has(id)) {
              seenSections.add(id);
              window.va?.('event', { name: 'section_view', data: { section: id } });
            }
          }
        });
      },
      // The "active band" is the middle 20% of the viewport — a section
      // becomes active when its visible middle crosses this band.
      { rootMargin: '-40% 0px -40% 0px' }
    );

    sections.forEach((section) => observer.observe(section));
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 1.5rem;
    left: 2rem;
    z-index: 50;
  }

  .nav ul {
    display: flex;
    align-items: center;
    gap: 3rem; /* 48px — matches Figma */
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav a {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300; /* Geist Mono Light */
    line-height: 1;
    color: #002d1a; /* deep dark British Racing Green */
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 180ms ease;
  }

  .nav a:hover {
    opacity: 0.7;
  }

  .nav a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* Active section — slight weight bump, no layout shift in monospace */
  .nav a[aria-current='page'] {
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav a {
      transition: none;
    }
  }
</style>
