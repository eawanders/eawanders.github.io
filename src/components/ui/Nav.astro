---
// Primary navigation (PER-164).
// Plain text labels, top-left of the viewport, deep dark British Racing Green
// on the warm canvas. Lowercase Geist Mono Light per the Figma design.

const items = [
  { href: '/', label: 'edward' },
  { href: '/about', label: 'about' },
  { href: '/research', label: 'research' },
  { href: '/projects', label: 'projects' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<nav class="nav" aria-label="Primary">
  <ul>
    {
      items.map(({ href, label }) => {
        const isActive = href === '/' ? pathname === '/' : pathname === href || pathname.startsWith(href + '/');
        return (
          <li>
            <a href={href} aria-current={isActive ? 'page' : undefined}>
              {label}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<style>
  .nav {
    position: fixed;
    top: 1.5rem;
    left: 2rem;
    z-index: 50;
  }

  .nav ul {
    display: flex;
    align-items: center;
    gap: 3rem; /* 48px — matches Figma */
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav a {
    display: inline-block;
    font-family: var(--font-body);
    font-size: 1rem; /* 20px — matches Figma */
    font-weight: 300; /* Geist Mono Light — matches Figma */
    line-height: 1;
    color: #002d1a; /* deep dark British Racing Green */
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 180ms ease;
  }

  .nav a:hover {
    opacity: 0.7;
  }

  .nav a:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* Active page — slight weight bump, no layout shift in monospace */
  .nav a[aria-current='page'] {
    font-weight: 500;
  }

  @media (prefers-reduced-motion: reduce) {
    .nav a {
      transition: none;
    }
  }
</style>
