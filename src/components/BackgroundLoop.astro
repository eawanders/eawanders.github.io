---
// Painterly oil-painting loop, framed as a canvas (PER-161 → PER-162 → PER-167).
// Cycles Day → Midpoint → Evening → Night → Dawn → Day every 18.4s.
// Reduced-motion fallback (PER-163): static Day-state poster shown instead of the loop
// when the user has `prefers-reduced-motion: reduce`. Both elements are decorative.
// Inset from viewport with a soft gradient feather (PER-167) so the loop reads as a
// painting on canvas rather than a full-bleed video.
---

<video
  class="bg-loop bg-loop--video"
  autoplay
  muted
  loop
  playsinline
  preload="auto"
  poster="/bg/bg-poster.jpg"
  aria-hidden="true"
>
  <source src="/bg/bg-loop-720p.webm" type="video/webm" media="(max-width: 768px)" />
  <source src="/bg/bg-loop-720p.mp4" type="video/mp4" media="(max-width: 768px)" />
  <source src="/bg/bg-loop-1080p.webm" type="video/webm" />
  <source src="/bg/bg-loop-1080p.mp4" type="video/mp4" />
</video>

<picture class="bg-loop bg-loop--poster" aria-hidden="true">
  <source srcset="/bg/bg-poster.webp" type="image/webp" />
  <img src="/bg/bg-poster.jpg" alt="" />
</picture>

<style>
  .bg-loop {
    /* Inset from each viewport edge — tune independently */
    --inset-top: 0vh;
    --inset-right: 0vw;
    --inset-bottom: 0vh;
    --inset-left: 10vw;

    /*
     * Radial vignette knobs — single elliptical mask fading the painting
     * into the page canvas. CSS radial-gradient cannot be rotated; for true
     * angled gradients an SVG mask is required (ask if needed).
     *
     *   --vignette-shape   ellipse | circle
     *   --vignette-size    Either an extent keyword (closest-side |
     *                      farthest-side | closest-corner | farthest-corner)
     *                      OR explicit ellipse axes as two lengths/percentages
     *                      (e.g. "100% 80%" — first value is horizontal radius,
     *                      second is vertical). Explicit axes give precise
     *                      control over how far the fade reaches in each
     *                      direction — useful for keeping specific corners
     *                      clear of the vignette.
     *   --vignette-cx,
     *   --vignette-cy      Centre position in % of the box. Can extend beyond
     *                      0–100% to push the centre off-screen.
     *   --vignette-stops   Gradient colour stops. Default is the simple two-
     *                      stop fade (opaque to --vignette-core, transparent
     *                      at --vignette-edge). Override with any valid stop
     *                      list for multi-stop / non-linear fades, e.g.
     *                      "black 0%, black 50%, transparent 100%".
     *   --vignette-core    (Used only by default --vignette-stops.) Radius (%)
     *                      where the opaque region ends.
     *   --vignette-edge    (Used only by default --vignette-stops.) Radius (%)
     *                      where the fade reaches transparent.
     *
     * Preset: far-right placement, top/bottom-right corners clear of vignette:
     *   --vignette-shape: ellipse;
     *   --vignette-size: 100% 100%;
     *   --vignette-cx: 100%; --vignette-cy: 50%;
     *   --vignette-stops: black 0%, black 50%, transparent 100%;
     */
    --vignette-shape: ellipse;
    --vignette-size: 130% 180%;
    --vignette-core: 15%;
    --vignette-edge: 57%;
    --vignette-cx: 100%;
    --vignette-cy: 50%;
    --vignette-stops: black 0%, black var(--vignette-core), transparent var(--vignette-edge);

    /*
     * Per-edge clear bands — force a specific edge transparent on top of
     * the radial vignette. Composited with the radial via mask intersection.
     *
     *   --clear-left       width (%) of the left edge faded out (0% = no effect).
     *                      Uniform vertical band: same intensity top to bottom.
     *
     *   --clear-top        vertical reach (%) of the top-left corner clearing,
     *                      measured at the LEFT edge of the box. The clearing
     *                      tapers elliptically toward the right.
     *   --clear-top-right  horizontal reach (%) of the top clearing, measured
     *                      at the TOP edge. 100% = clearing extends the full
     *                      width; 0% = no clearing; lower values keep the
     *                      right-hand side fully painted.
     *
     * The top clear is shaped as an ellipse anchored at the top-left corner,
     * so the top-left is fully transparent and the fade falls off to fully
     * opaque on the diagonal toward the bottom-right.
     */
    --clear-left: 0%;
    --clear-top: 0%;
    --clear-top-right: 100%;

    /*
     * Background offset — shifts which part of the painting is visible
     * inside the bg-loop box. Applied as object-position on the video and
     * the poster. 0% = align that edge of the painting to that edge of the
     * box; 50% = centred (default); 100% = opposite edge aligned.
     * E.g. --bg-offset-x: 0% reveals more of the painting's left side.
     */
    --bg-offset-x: 100%;
    --bg-offset-y: 0%;

    position: fixed;
    top: var(--inset-top);
    left: var(--inset-left);
    width: calc(100vw - var(--inset-left) - var(--inset-right));
    height: calc(100vh - var(--inset-top) - var(--inset-bottom));
    z-index: -1;
    pointer-events: none;

    /*
     * Three-layer mask, composited with intersection:
     *   1. Radial vignette (overall elliptical fade)
     *   2. Left clear band (extra fade on the left edge)
     *   3. Top clear band (extra fade on the top edge)
     * Anywhere any layer is transparent, the final is transparent.
     */
    -webkit-mask-image:
      radial-gradient(
        var(--vignette-shape) var(--vignette-size) at var(--vignette-cx) var(--vignette-cy),
        var(--vignette-stops)
      ),
      linear-gradient(to right, transparent 0%, black var(--clear-left), black 100%),
      radial-gradient(
        ellipse var(--clear-top-right) var(--clear-top) at 0% 0%,
        transparent 0%,
        black 100%
      );
    -webkit-mask-composite: source-in;
    mask-image:
      radial-gradient(
        var(--vignette-shape) var(--vignette-size) at var(--vignette-cx) var(--vignette-cy),
        var(--vignette-stops)
      ),
      linear-gradient(to right, transparent 0%, black var(--clear-left), black 100%),
      radial-gradient(
        ellipse var(--clear-top-right) var(--clear-top) at 0% 0%,
        transparent 0%,
        black 100%
      );
    mask-composite: intersect;
  }

  @media (max-width: 768px) {
    .bg-loop {
      --inset-top: 16px;
      --inset-right: 16px;
      --inset-bottom: 16px;
      --inset-left: 16px;
      --vignette-core: 40%;
    }
  }

  .bg-loop--video {
    object-fit: cover;
    object-position: var(--bg-offset-x) var(--bg-offset-y);
    /* Crop the very edge of the video — hides 1px dark rows from encoding */
    transform: scale(1.03);
    transform-origin: center;
  }

  .bg-loop--poster {
    display: none;
  }

  .bg-loop--poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--bg-offset-x) var(--bg-offset-y);
    /* Crop the very edge of the poster — keep parity with the video */
    transform: scale(1.03);
    transform-origin: center;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-loop--video {
      display: none;
    }

    .bg-loop--poster {
      display: block;
    }
  }
</style>
