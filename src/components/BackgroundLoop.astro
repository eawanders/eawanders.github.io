---
// Painterly oil-painting loop, framed as a canvas (PER-161 → PER-162 → PER-167).
// Cycles Day → Midpoint → Evening → Night → Dawn → Day every 18.4s.
// Reduced-motion fallback (PER-163): static Day-state poster shown instead of the loop
// when the user has `prefers-reduced-motion: reduce`. Both elements are decorative.
// Inset from viewport with a soft gradient feather (PER-167) so the loop reads as a
// painting on canvas rather than a full-bleed video.
---

<video
  class="bg-loop bg-loop--video"
  autoplay
  muted
  loop
  playsinline
  preload="auto"
  poster="/bg/bg-poster.jpg"
  aria-hidden="true"
>
  <source src="/bg/bg-loop-720p.webm" type="video/webm" media="(max-width: 768px)" />
  <source src="/bg/bg-loop-720p.mp4" type="video/mp4" media="(max-width: 768px)" />
  <source src="/bg/bg-loop-1080p.webm" type="video/webm" />
  <source src="/bg/bg-loop-1080p.mp4" type="video/mp4" />
</video>

<picture class="bg-loop bg-loop--poster" aria-hidden="true">
  <source srcset="/bg/bg-poster.webp" type="image/webp" />
  <img src="/bg/bg-poster.jpg" alt="" />
</picture>

<style>
  .bg-loop {
    --canvas-feather: 12%;

    position: fixed;
    inset: 5vh 5vw;
    z-index: -1;
    pointer-events: none;

    /* Soft gradient feather on all four edges — fades into page canvas */
    -webkit-mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        black var(--canvas-feather),
        black calc(100% - var(--canvas-feather)),
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        black var(--canvas-feather),
        black calc(100% - var(--canvas-feather)),
        transparent 100%
      );
    -webkit-mask-composite: source-in;
    mask-image:
      linear-gradient(
        to right,
        transparent 0%,
        black var(--canvas-feather),
        black calc(100% - var(--canvas-feather)),
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        transparent 0%,
        black var(--canvas-feather),
        black calc(100% - var(--canvas-feather)),
        transparent 100%
      );
    mask-composite: intersect;
  }

  @media (max-width: 768px) {
    .bg-loop {
      inset: 16px;
      --canvas-feather: 8%;
    }
  }

  .bg-loop--video {
    object-fit: cover;
  }

  .bg-loop--poster {
    display: none;
  }

  .bg-loop--poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-loop--video {
      display: none;
    }

    .bg-loop--poster {
      display: block;
    }
  }
</style>
