---
// Painterly oil-painting loop, framed as a canvas (PER-161 → PER-162 → PER-167).
// Reusable per-section background (PER-144): each instance is wrapped in a
// .bg-loop-layer container so it can be opacity-faded independently as the
// user scrolls. Vignette/inset/offset variables live on the wrapper and the
// inner .bg-loop-frame (which carries the mask) reads them.
//
// PER-158 refactor: the mask used to be applied directly to the <video> and
// <picture> elements, as four comma-separated gradient layers composited
// with intersect. Two well-documented WebKit issues broke this on Safari
// (desktop + iOS) and Chrome-on-iOS (which is WebKit under the hood):
//   1. Masking a <video> directly is unreliable — video paints through a
//      separate GPU compositor pass that WebKit doesn't consistently merge
//      with CSS masks. Applying the mask to a regular wrapping <div> is
//      reliable across all engines.
//   2. Three of the four mask layers degenerated to identical 0% stops
//      (the --clear-left/top/bottom defaults are 0% and no section
//      overrides them). Chromium tolerates "two stops at the same offset"
//      as fully opaque; WebKit resolves the bottom layer as fully
//      transparent, which intersected the entire painting to invisible.
// Fixed by moving the mask to .bg-loop-frame and collapsing to a single
// radial-vignette gradient. The clear-* knobs are gone — they were unused.
//
// Props:
//   sectionKey  String. Used as `data-bg-section` for cross-fade scripts to
//               match a layer to the section that should reveal it. Defaults
//               to "top" (the hero).
//   videoBase   Base path for video sources. Resolves to
//               `${videoBase}-720p.{webm,mp4}` and `${videoBase}-1080p.{webm,mp4}`.
//   posterBase  Base path for the reduced-motion poster. Resolves to
//               `${posterBase}.{webp,jpg}`.
//   style       Optional inline style for per-instance variable overrides,
//               e.g. "--vignette-cx: 0%; --bg-offset-x: 0%;".

interface Props {
  sectionKey?: string;
  videoBase?: string;
  posterBase?: string;
  style?: string;
  // `preload` is forwarded to the <video> element. Default `"none"` so
  // off-screen sections don't tax the initial page load — the hero passes
  // `"auto"` explicitly. (PER-156 perf pass.)
  preload?: 'none' | 'metadata' | 'auto';
  // Forwarded to the `<video>`. Hero passes "high" so the LCP-candidate
  // poster is fetched ahead of off-screen assets.
  fetchPriority?: 'high' | 'low' | 'auto';
}

const {
  sectionKey = 'top',
  videoBase = '/bg/bg-loop',
  posterBase = '/bg/bg-poster',
  style,
  preload = 'none',
  fetchPriority = 'auto',
} = Astro.props;
---

<div class="bg-loop-layer" data-bg-section={sectionKey} style={style}>
  <div class="bg-loop-frame">
    <video
      class="bg-loop bg-loop--video"
      autoplay
      muted
      loop
      playsinline
      preload={preload}
      poster={`${posterBase}.webp`}
      fetchpriority={fetchPriority}
      aria-hidden="true"
    >
      <source src={`${videoBase}-720p.webm`} type="video/webm" media="(max-width: 768px)" />
      <source src={`${videoBase}-720p.mp4`} type="video/mp4" media="(max-width: 768px)" />
      <source src={`${videoBase}-1080p.webm`} type="video/webm" />
      <source src={`${videoBase}-1080p.mp4`} type="video/mp4" />
    </video>

    <picture class="bg-loop bg-loop--poster" aria-hidden="true">
      <source srcset={`${posterBase}.webp`} type="image/webp" />
      <img src={`${posterBase}.jpg`} alt="" />
    </picture>
  </div>
</div>

<script>
  /*
   * Safari (macOS in particular) sometimes refuses to honour the declarative
   * `autoplay` attribute on muted videos when the page wasn't activated by
   * a user gesture, and then renders its "start playback" control overlay
   * on top of the painting. Calling .play() explicitly forces the issue —
   * if Safari permits autoplay it's a no-op; if it doesn't, this triggers
   * the same blocked-autoplay path silently (returns a rejected promise)
   * but the controls remain hidden by the CSS rules above.
   */
  document.querySelectorAll<HTMLVideoElement>('.bg-loop--video').forEach((video) => {
    const promise = video.play();
    if (promise && typeof promise.catch === 'function') {
      promise.catch(() => {
        // Autoplay blocked — poster fallback continues to show.
      });
    }
  });
</script>

<style>
  .bg-loop-layer {
    /*
     * Inset from each viewport edge — tune independently. Top and bottom
     * use a small negative inset so the element overflows the viewport by
     * 4px on each end; the clip-path below crops those 4px back off, hiding
     * the dark rows baked into the video edges while keeping the visible
     * painting flush with the viewport (no cream gap top or bottom).
     */
    --inset-top: -4px;
    --inset-right: 0vw;
    --inset-bottom: -4px;
    --inset-left: -10vw;

    /*
     * Radial vignette knobs — see comments below for the per-variable detail.
     * Override per instance via the `style` prop.
     */
    --vignette-shape: ellipse;
    --vignette-size: 110% 180%;
    --vignette-core: 25%;
    --vignette-edge: 57%;
    --vignette-cx: 100%;
    --vignette-cy: 50%;
    --vignette-stops: black 0%, black var(--vignette-core), transparent var(--vignette-edge);

    --bg-offset-x: 100%;
    --bg-offset-y: 0%;

    /*
     * --bg-shift-y  literal pixel/length translation applied to the video
     *               frame via transform: translateY(). Use to nudge the
     *               video up or down inside its layer when the box aspect
     *               matches the video aspect (so object-position can't
     *               crop). Positive values move the video down.
     */
    --bg-shift-y: 0px;

    position: fixed;
    inset: 0;
    /*
     * z-index: 0 (not -1). On iOS Safari, position: fixed elements with a
     * negative z-index are rendered BEHIND the root canvas, hiding the
     * painting under whatever background colour is set on <html> or <body>.
     * All overlay content has positive z-index (fixed-content: 10, nav: 50,
     * hamburger/menu: 40-60), so z-index: 0 keeps the layer behind content
     * while still painting on top of the root canvas everywhere.
     */
    z-index: 0;
    pointer-events: none;
  }

  /*
   * Vignette controls:
   *   --vignette-shape   ellipse | circle
   *   --vignette-size    extent keyword OR explicit "rx ry" lengths
   *   --vignette-cx/cy   centre of the gradient in % of the box
   *   --vignette-stops   gradient colour stops — override for non-linear fades
   *   --vignette-core    opaque-region radius (% along the gradient line)
   *   --vignette-edge    transparent radius (% along the gradient line)
   *   --bg-offset-x/y    object-position for the painting inside the frame
   *   --bg-shift-y       additional translateY applied to the painting
   */

  /*
   * The frame carries the mask AND the sizing. Children (video + poster)
   * fill it and inherit visibility from the mask. WebKit renders this
   * correctly because the mask is on a plain block element, not on the
   * <video> element directly.
   */
  .bg-loop-frame {
    position: absolute;
    top: var(--inset-top);
    left: var(--inset-left);
    width: calc(100vw - var(--inset-left) - var(--inset-right));
    height: calc(100vh - var(--inset-top) - var(--inset-bottom));
    overflow: hidden;
    -webkit-mask-image: radial-gradient(
      var(--vignette-shape) var(--vignette-size) at var(--vignette-cx) var(--vignette-cy),
      var(--vignette-stops)
    );
    mask-image: radial-gradient(
      var(--vignette-shape) var(--vignette-size) at var(--vignette-cx) var(--vignette-cy),
      var(--vignette-stops)
    );
  }

  .bg-loop {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .bg-loop-layer {
      --inset-top: 16px;
      --inset-right: 16px;
      --inset-bottom: 16px;
      --inset-left: 16px;
      --vignette-core: 40%;
    }
  }

  .bg-loop--video {
    object-fit: cover;
    object-position: var(--bg-offset-x) var(--bg-offset-y);
    /*
     * The bg-loop-layer already has pointer-events: none, but Safari
     * sometimes still shows a "start playback" overlay on muted-autoplay
     * <video> elements when autoplay is blocked. Setting it explicitly
     * here is belt-and-braces.
     */
    pointer-events: none;
    /*
     * Crop the top and bottom edges of the video to hide ~1px dark rows
     * baked into the source encoding. Uses clip-path rather than transform:
     * scale() because a scaled `position: fixed` masked element produces a
     * 1px AA artefact at its CSS box edge — visible as a faint vertical
     * line at --inset-left. clip-path has no such compositor side-effect.
     */
    clip-path: inset(4px 0 4px 0);
    transform: translateY(var(--bg-shift-y));
  }

  /*
   * WebKit media-control overlay killers. Safari (macOS and iOS) renders a
   * "tap to play" overlay on <video> elements when it considers autoplay
   * to have been blocked, even when the video is decorative and has no
   * `controls` attribute. Hiding both the inline start-playback button
   * and the centred overlay-play button removes the visible affordance.
   * Paired with the explicit `.play()` call in <script> below — if Safari
   * actually permits autoplay, the controls never show anyway; if it
   * doesn't, JS forces the play and the controls remain hidden.
   */
  .bg-loop--video::-webkit-media-controls-start-playback-button {
    display: none !important;
    -webkit-appearance: none;
  }

  .bg-loop--video::-webkit-media-controls-overlay-play-button {
    display: none !important;
    -webkit-appearance: none;
  }

  .bg-loop--video::-webkit-media-controls {
    display: none !important;
  }

  .bg-loop--poster {
    display: none;
  }

  .bg-loop--poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: var(--bg-offset-x) var(--bg-offset-y);
    clip-path: inset(4px 0 4px 0);
    transform: translateY(var(--bg-shift-y));
    display: block;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg-loop--video {
      display: none;
    }

    .bg-loop--poster {
      display: block;
    }
  }
</style>
