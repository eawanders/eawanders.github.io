---
import BackgroundLoop from '../components/BackgroundLoop.astro';
import Nav from '../components/ui/Nav.astro';
import '../styles/fonts.css';
import '../styles/tokens.css';

const pageTitle = 'Edward Anders';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/CaslonOldFace-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
      }
      body {
        font-family: var(--font-body);
        background: #f5f2ec;
      }
      .hero {
        position: fixed;
        top: 50%;
        left: 2rem;
        transform: translateY(-50%);
        max-width: 32rem;
        z-index: 10;
        color: #002d1a;
      }
      .hero h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1rem;
      }
      .hero p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.5;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <BackgroundLoop />
    <Nav />
    <main class="hero">
      <h1>{pageTitle}</h1>
      <p>Researching the political and societal impacts of AI. Data science PhD at the University of Oxford. Building the infrastructure for synthetic agents.</p>
    </main>
  </body>
</html>
