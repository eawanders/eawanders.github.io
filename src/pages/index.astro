---
import BackgroundLoop from '../components/BackgroundLoop.astro';
import Nav from '../components/ui/Nav.astro';
import '../styles/fonts.css';
import '../styles/tokens.css';

const pageTitle = 'Edward Anders';

// Per-section vignette/inset overrides. The hero now uses the runner-through-
// fields video with a bottom-anchored vignette (top half cream, bottom half
// painting). About keeps the oil painting with a left-anchored vignette.
// Research reuses the oil painting with the right-anchored vignette that the
// hero used to have, so the page reads as an ABAB rhythm (hero/about share a
// fade band, about/research share the oil painting visually).
const heroBgStyle = [
  '--inset-top: 10vh',
  '--inset-left: 0vw',
  '--inset-right: 0vw',
  '--vignette-shape: ellipse',
  '--vignette-size: 180% 100%',
  '--vignette-cx: 50%',
  '--vignette-cy: 60%',
  '--vignette-core: 15%',
  '--vignette-edge: 50%',
  '--bg-offset-x: 50%',
  '--bg-offset-y: 100%',
  '--bg-shift-y: 80px',
  'opacity: 1',
].join('; ');

const aboutBgStyle = [
  // Mirror the vignette + offset to the left so the painting reveals on the
  // opposite side from the hero. Insets and vignette sizing come from the
  // component defaults.
  '--vignette-cx: 0%',
  '--bg-offset-x: 0%',
  'opacity: 0',
].join('; ');

// Research uses the oil painting (default videoBase) with the right-anchored
// vignette setup the hero originally had — 10vw cream rail on the left, wider
// ellipse, smaller opaque core.
const researchBgStyle = [
  '--inset-left: 10vw',
  '--vignette-size: 130% 180%',
  '--vignette-core: 15%',
  'opacity: 0',
].join('; ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/CaslonOldFace-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 4rem;
        /*
         * Mandatory scroll-snap on each section's top edge — the page
         * always settles at a section boundary so the user doesn't drift
         * mid-transition.
         */
        scroll-snap-type: y mandatory;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
          scroll-snap-type: none;
        }
      }
      body {
        margin: 0;
        font-family: var(--font-body);
        background: #f5f2ec;
        color: #002d1a;
      }
      .section {
        position: relative;
        min-height: 100vh;
        padding: 6rem 2rem 4rem;
        box-sizing: border-box;
        scroll-snap-align: start;
        scroll-snap-stop: always;
      }
      .section h2,
      .fixed-content h2 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1.5rem;
      }
      .section h3,
      .fixed-content h3 {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        margin: 2rem 0 0.75rem;
      }
      .section p,
      .fixed-content p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: 32rem;
        margin: 0 0 1rem;
      }
      .section ul,
      .fixed-content ul {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: 32rem;
        margin: 0 0 1rem;
        padding: 0;
        list-style: none;
      }
      .section ul li,
      .fixed-content ul li {
        margin: 0 0 0.25rem;
      }
      /*
       * Fixed-position content blocks — sit at vertical-centre of the
       * viewport on opposite sides. They do not scroll with the page;
       * they only fade in/out via opacity tied to scroll progress.
       * This keeps the typography visually settled while the background
       * cross-fades between sections.
       */
      .fixed-content {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        max-width: 32rem;
        /*
         * border-box so max-height (and width) include padding — otherwise
         * a large padding-top on the about block would push the element
         * past the bottom of the viewport, making the bottom of the inner
         * scroll unreachable.
         */
        box-sizing: border-box;
        z-index: 10;
        will-change: opacity;
        /*
         * pointer-events default to none; the scroll script toggles them
         * to `auto` when the block becomes visible. Otherwise an invisible
         * fixed block (opacity 0) would still intercept wheel and click
         * events over half the viewport, blocking page scroll.
         */
        pointer-events: none;
      }
      .fixed-content--right {
        right: 2rem;
      }
      /*
       * Inner scroll for any content block with long-form content (about,
       * research, etc). The hero is short and never gets this modifier —
       * keeps it from becoming a wheel-capturing scroll container that
       * could interfere with page scroll.
       */
      .fixed-content--scroll {
        padding-top: 10rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        overscroll-behavior: contain;
        scrollbar-width: thin;
        scrollbar-color: rgba(0, 45, 26, 0.35) transparent;
      }
      .fixed-content--scroll::-webkit-scrollbar {
        width: 6px;
      }
      .fixed-content--scroll::-webkit-scrollbar-track {
        background: transparent;
      }
      .fixed-content--scroll::-webkit-scrollbar-thumb {
        background: rgba(0, 45, 26, 0.35);
        border-radius: 3px;
      }
      /*
       * Accordion items — native <details>/<summary> with a custom chevron.
       * Hides the browser's default marker, draws a `>` on the left of each
       * summary, and rotates it 90° when the item is open.
       */
      .fixed-content details {
        margin: 0 0 0.5rem;
      }
      .fixed-content summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        user-select: none;
      }
      .fixed-content summary::-webkit-details-marker {
        display: none;
      }
      .fixed-content summary::before {
        content: '›';
        display: inline-block;
        flex-shrink: 0;
        font-weight: 400;
        transform-origin: center 55%;
        transition: transform 180ms ease;
      }
      .fixed-content details[open] summary::before {
        transform: rotate(90deg);
      }
      .fixed-content details > *:not(summary) {
        margin: 0.25rem 0 0.5rem 1.4rem;
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.55;
        opacity: 0.82;
      }
      /* Date line inside an accordion — distinct from the description paragraph */
      .fixed-content details .date {
        font-weight: 500;
        opacity: 1;
        margin-bottom: 0.35rem;
      }
      /*
       * Additional subtext inside an accordion — sits between the date and
       * the description. Use for scholarships, honours, sub-titles, etc.
       * Regular weight, full opacity, kept tight against the date above.
       */
      .fixed-content details .additional-subtext {
        font-weight: 400;
        opacity: 1;
        margin-top: -0.15rem;
        margin-bottom: 0.5rem;
      }
      /* Inline text link — used for the CV download at the bottom of about */
      .fixed-content a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 0.2em;
        transition: opacity 180ms ease;
      }
      .fixed-content a:hover {
        opacity: 0.7;
      }
      .fixed-content a:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 4px;
        border-radius: 2px;
      }
      .fixed-content .cv-download {
        /*
         * Higher specificity than the global `.fixed-content p` rule, so the
         * top margin actually wins. Gives the CV link breathing room from
         * the last accordion above.
         */
        margin: 2rem 0 0;
        font-size: 1rem;
        font-weight: 300;
      }
      .fixed-content--left {
        left: 2rem;
      }
      /*
       * Hero block — overrides .fixed-content / .fixed-content--left so the
       * title sits centred horizontally and anchored closer to the top of
       * the viewport (instead of vertically centred at left). Sits on the
       * cream band above the bottom-anchored hero vignette.
       */
      .fixed-content.hero {
        top: 15vh;
        left: 50%;
        right: auto;
        transform: translateX(-50%);
        text-align: center;
        max-width: 40rem;
      }
      .hero h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1rem;
      }
      .hero p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.5;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <BackgroundLoop
      sectionKey="top"
      videoBase="/bg/research-loop"
      posterBase="/bg/research-poster"
      style={heroBgStyle}
    />
    <BackgroundLoop sectionKey="about" style={aboutBgStyle} />
    <BackgroundLoop sectionKey="research" style={researchBgStyle} />
    <Nav />

    <!--
      Fixed-position content blocks — sit at vertical-centre of the viewport
      and cross-fade via opacity tied to scroll progress. The empty sections
      below provide scroll length and snap targets for the page.
    -->
    <div class="hero fixed-content fixed-content--left" data-section-content="top">
      <h1>{pageTitle}</h1>
      <p>
        Researching the political and societal impacts of AI. Data science PhD at the University of
        Oxford. Building the infrastructure for synthetic agents.
      </p>
    </div>

    <div
      class="fixed-content fixed-content--right fixed-content--scroll"
      data-section-content="about"
      style="opacity: 0"
    >
      <h2>About</h2>
      <p>
        Edward is a DPhil candidate in Social Data Science at the Oxford Internet Institute,
        building synthetic electorates to predict political behaviour.
      </p>

      <h3>Education</h3>
      <ul>
        <li>
          <details>
            <summary>DPhil Social Data Science — Jesus College, Oxford</summary>
            <p class="date">2026–</p>
            <p class="additional-subtext">
              Shirley Scholar</p>
            <p>
              <p>Oxford Internet Institute. Using synthetic agent-based models of the Uk electorate to predict political behaviour under different AI-generated treatments.</p>
            </p>
          </details>
          <li>
            <details>
              <summary
                >MPhil Politics — St Antony's College, Oxford</summary
              >
              <p class="date">2024–2026</p>
              <p class="additional-subtext">Dahrendorf Scholar</p>
              <p>
                Papers on advanced experimental, quantitative, and computational social science. Thesis investigated whether labelling
                AI-generated political content mitigates or deepens affective polarisation using survey experiments funded by YouGov.              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>BSc Economics and Politics — University of Bristol</summary>
              <p class="date">2018–2021</p>
              <p>
                1st-Class Honours. Head of School's Commendation for the dissertation and final
                year.
              </p>
            </details>
          </li>
        </li>

        <h3>Experience</h3>
        <ul>
          <li>
            <details>
              <summary>Graduate Researcher — Nuffield College, Oxford</summary>
              <p class="date">2025–</p>
              <p>
                Assisting Professor Rachel Bernhard on her Appearance-Based Politics book project.
                Built PDF scraping and data-extraction pipelines in Python and built reproducible analysis scripts in R.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Research Analyst — Oxford Levant Advisory</summary>
              <p class="date">2025–</p>
              <p>
                Building data solutions for a geopolitical risk consultancy. Developed a pipeline of live news and social media data on the Middle East building an open-source media map.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Strategy Research Manager — Complyance</summary>
              <p class="date">2024–2025</p>
              <p>
                Employee #10 at a seed-stage AI GRC startup. Backed by Creandum. Established a post-sales department with the CSO and CEO. Led cybersecurity research across the EU AI Act, SOC2, ISO 27001, GDPR, and HIPPA for clients to define how forward-deployed engineering teams can deploy AI compliance agents.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Senior Founder's Associate — Compose</summary>
              <p class="date">2021–2024</p>
              <p>
                Employee #1 at a Creandum-backed seed-stage startup building an all-in-one inbox management tool. Led operations and GTM as well as building the data infrastructure and analytics for user behaviour and growth. Hired and managed the first 5 employees across engineering, product, and growth functions.
              </p>
            </details>
          </li>
        </ul>

        <p class="cv-download">
          <a href="/edward-anders-cv.pdf" target="_blank" rel="noopener"
            >Download full curriculum vitae</a
          >
        </p>
      </div>

      <div
        class="fixed-content fixed-content--left fixed-content--scroll"
        data-section-content="research"
        style="opacity: 0"
      >
        <h2>Research</h2>
        <p>
          Placeholder research intro — one or two sentences framing the focus areas (synthetic
          electorates, AI-generated content and political behaviour, affective polarisation) and
          methods.
        </p>

        <h3>Publications</h3>
        <ul>
          <li>
            <details>
              <summary
                >Talking To Machines: Synthetic Replication Games — Duch, Batistoni et al.</summary
              >
              <p class="date">Forthcoming</p>
              <p class="additional-subtext">PNAS / Nature Computational Science (in preparation)</p>
              <p>
                Co-author on a paper from the Talking to Machines project at Nuffield College,
                Oxford — a platform to facilitate the design, conduct, and analysis of large-scale
                experimental trials using LLM-powered agents.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>MPhil research paper on AI labelling and affective polarisation</summary>
              <p class="date">Working paper · 2026</p>
              <p>
                Two YouGov-fielded UK survey experiments and a formal theoretical model linking AI
                content labels through trust and emotion to polarisation outcomes. Speaks to the
                EU AI Act's content-disclosure requirements.
              </p>
              <p>
                <a href="/edward-anders-mphil-thesis.pdf" target="_blank" rel="noopener"
                  >Download thesis (PDF)</a
                >
              </p>
            </details>
          </li>
        </ul>

        <h3>Grants &amp; awards</h3>
        <ul>
          <li>
            <details>
              <summary>Oxford CESS Research Grant</summary>
              <p class="date">2025</p>
              <p>£1,500 from the Centre for Experimental Social Sciences.</p>
            </details>
          </li>
          <li>
            <details>
              <summary>Norman Chester Fund Research Grant</summary>
              <p class="date">2025</p>
              <p>£1,000 awarded for thesis research.</p>
            </details>
          </li>
          <li>
            <details>
              <summary>YouGov UniOM Survey Experiment Grant</summary>
              <p class="date">2024 &amp; 2025</p>
              <p>Awarded twice, ~£1,000 each, to field two nationally representative UK survey experiments.</p>
            </details>
          </li>
        </ul>
      </div>

      <main>
        <section id="top" class="section"></section>
        <section id="about" class="section"></section>
        <section id="research" class="section"></section>
        <section id="projects" class="section">
          <h2>Projects</h2>
          <p>Placeholder content for the projects section. Selected work coming soon.</p>
        </section>
      </main>

      <script>
        // Data-driven scroll-spy cross-fade (PER-144, PER-146).
        //
        // Each section gets matched to (a) a background layer with
        // data-bg-section and (b) optionally a fixed-content text block with
        // data-section-content. Section ordering in the DOM defines the
        // index; the scroll progress is measured in units of one hero-height
        // (sections are min-height 100vh, so progress = scrollY / heroHeight
        // gives 0 at #top, 1 at #about, 2 at #research, ...).
        //
        // For each layer / text we apply a smoothstep fade-in coming from
        // the previous section and a smoothstep fade-out going to the next.
        // The hero (index 0) has no fade-in; the last mounted layer has no
        // fade-out (it stays visible past its section, since no successor
        // exists yet).
        //
        // rAF-throttled passive listener. prefers-reduced-motion disables
        // the effect and the initial inline opacities take over.
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
        const bgLayers = Array.from(
          document.querySelectorAll<HTMLElement>('.bg-loop-layer[data-bg-section]'),
        );
        const textBlocks = Array.from(
          document.querySelectorAll<HTMLElement>('.fixed-content[data-section-content]'),
        );

        if (!prefersReducedMotion && sections.length && bgLayers.length && textBlocks.length) {
          let ticking = false;

          const clamp01 = (x: number) => Math.max(0, Math.min(1, x));
          const smoothstep = (t: number) => t * t * (3 - 2 * t);

          // Map each section id to its DOM-order index.
          const sectionIndex: Record<string, number> = {};
          sections.forEach((s, i) => {
            sectionIndex[s.id] = i;
          });

          /*
           * Text-block visibility.
           *   Section 0 (hero): visible at progress 0, fades out 0 → 0.4
           *   Section i ≥ 1:    fade in (i − 0.5) → (i − 0.1)
           *                     fade out i → (i + 0.4)
           */
          const TEXT_FADE_RANGE = 0.4;
          const textOpacity = (progress: number, i: number) => {
            if (i === 0) {
              return 1 - smoothstep(clamp01(progress / TEXT_FADE_RANGE));
            }
            const fadeIn = smoothstep(
              clamp01((progress - (i - 0.5)) / TEXT_FADE_RANGE),
            );
            const fadeOut =
              1 - smoothstep(clamp01((progress - i) / TEXT_FADE_RANGE));
            return Math.min(fadeIn, fadeOut);
          };

          /*
           * Background-layer visibility.
           *   Section 0 (hero): visible at progress 0, fades out 0 → 0.75
           *   Section i ≥ 1:    fade in (i − 1) → (i − 0.25)
           *                     fade out i → (i + 0.75)  (skipped on last)
           * The last mounted bg layer never fades out — it stays visible
           * for any progress past its section.
           */
          const BG_FADE_RANGE = 0.75;
          const bgOpacity = (progress: number, i: number, isLast: boolean) => {
            if (i === 0) {
              return 1 - smoothstep(clamp01(progress / BG_FADE_RANGE));
            }
            const fadeIn = smoothstep(
              clamp01((progress - (i - 1)) / BG_FADE_RANGE),
            );
            if (isLast) return fadeIn;
            const fadeOut =
              1 - smoothstep(clamp01((progress - i) / BG_FADE_RANGE));
            return Math.min(fadeIn, fadeOut);
          };

          const update = () => {
            const heroHeight = sections[0].getBoundingClientRect().height;
            const progress = window.scrollY / Math.max(heroHeight, 1);

            bgLayers.forEach((layer, idx) => {
              const key = layer.getAttribute('data-bg-section') ?? '';
              const sectionIdx = sectionIndex[key] ?? idx;
              const isLast = idx === bgLayers.length - 1;
              layer.style.opacity = bgOpacity(progress, sectionIdx, isLast).toString();
            });

            textBlocks.forEach((block) => {
              const key = block.getAttribute('data-section-content') ?? '';
              const sectionIdx = sectionIndex[key] ?? 0;
              const o = textOpacity(progress, sectionIdx);
              block.style.opacity = o.toString();
              /*
               * Toggle pointer-events with visibility. Fixed blocks cover
               * portions of the viewport even when fully transparent, so
               * an invisible block would otherwise swallow wheel and click
               * events and block page scroll.
               */
              block.style.pointerEvents = o > 0.05 ? 'auto' : 'none';
            });

            ticking = false;
          };

          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          };

          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      </script>
    </div>
  </body>
</html>
