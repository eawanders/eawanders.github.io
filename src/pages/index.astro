      </div>

      <main>
        <section id="home" class="section"></section>
        <section id="about" class="section"></section>
        <section id="research" class="section"></section>
        <section id="projects" class="section"></section>
        <section id="contact" class="section"></section>
      </main>

      <script>
        // Data-driven scroll-spy cross-fade (PER-144, PER-146).
        //
        // Each section gets matched to (a) a background layer with
        // data-bg-section and (b) optionally a fixed-content text block with
        // data-section-content. Section ordering in the DOM defines the
        // index; the scroll progress is measured in units of one hero-height
        // (sections are min-height 100vh, so progress = scrollY / heroHeight
        // gives 0 at #home, 1 at #about, 2 at #research, ...).
        //
        // For each layer / text we apply a smoothstep fade-in coming from
        // the previous section and a smoothstep fade-out going to the next.
        // The hero (index 0) has no fade-in; the last mounted layer has no
        // fade-out (it stays visible past its section, since no successor
        // exists yet).
        //
        // rAF-throttled passive listener. prefers-reduced-motion disables
        // the effect and the initial inline opacities take over.
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const sections = Array.from(document.querySelectorAll<HTMLElement>('section[id]'));
        const bgLayers = Array.from(
          document.querySelectorAll<HTMLElement>('.bg-loop-layer[data-bg-section]'),
        );
        const textBlocks = Array.from(
          document.querySelectorAll<HTMLElement>('.fixed-content[data-section-content]'),
        );

        if (!prefersReducedMotion && sections.length && bgLayers.length && textBlocks.length) {
          let ticking = false;

          const clamp01 = (x: number) => Math.max(0, Math.min(1, x));
          const smoothstep = (t: number) => t * t * (3 - 2 * t);

          // Map each section id to its DOM-order index.
          const sectionIndex: Record<string, number> = {};
          sections.forEach((s, i) => {
            sectionIndex[s.id] = i;
          });

          /*
           * Text-block visibility.
           *   Section 0 (hero): visible at progress 0, fades out 0 → 0.4
           *   Section i ≥ 1:    fade in (i − 0.5) → (i − 0.1)
           *                     fade out i → (i + 0.4)
           */
          const TEXT_FADE_RANGE = 0.4;
          const textOpacity = (progress: number, i: number) => {
            if (i === 0) {
              return 1 - smoothstep(clamp01(progress / TEXT_FADE_RANGE));
            }
            const fadeIn = smoothstep(
              clamp01((progress - (i - 0.5)) / TEXT_FADE_RANGE),
            );
            const fadeOut =
              1 - smoothstep(clamp01((progress - i) / TEXT_FADE_RANGE));
            return Math.min(fadeIn, fadeOut);
          };

          /*
           * Background-layer visibility.
           *   Section 0 (hero): visible at progress 0, fades out 0 → 0.75
           *   Section i ≥ 1:    fade in (i − 1) → (i − 0.25)
           *                     fade out i → (i + 0.75)  (skipped on last)
           * The last mounted bg layer never fades out — it stays visible
           * for any progress past its section.
           */
          const BG_FADE_RANGE = 0.75;
          const bgOpacity = (progress: number, i: number, isLast: boolean) => {
            if (i === 0) {
              return 1 - smoothstep(clamp01(progress / BG_FADE_RANGE));
            }
            const fadeIn = smoothstep(
              clamp01((progress - (i - 1)) / BG_FADE_RANGE),
            );
            if (isLast) return fadeIn;
            const fadeOut =
              1 - smoothstep(clamp01((progress - i) / BG_FADE_RANGE));
            return Math.min(fadeIn, fadeOut);
          };

          const update = () => {
            const heroHeight = sections[0].getBoundingClientRect().height;
            const progress = window.scrollY / Math.max(heroHeight, 1);

            bgLayers.forEach((layer, idx) => {
              const key = layer.getAttribute('data-bg-section') ?? '';
              const sectionIdx = sectionIndex[key] ?? idx;
              const isLast = idx === bgLayers.length - 1;
              layer.style.opacity = bgOpacity(progress, sectionIdx, isLast).toString();
            });

            textBlocks.forEach((block) => {
              const key = block.getAttribute('data-section-content') ?? '';
              const sectionIdx = sectionIndex[key] ?? 0;
              const o = textOpacity(progress, sectionIdx);
              block.style.opacity = o.toString();
              /*
               * Toggle pointer-events with visibility. Fixed blocks cover
               * portions of the viewport even when fully transparent, so
               * an invisible block would otherwise swallow wheel and click
               * events and block page scroll.
               */
              block.style.pointerEvents = o > 0.05 ? 'auto' : 'none';
            });

            ticking = false;
          };

          const onScroll = () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          };

          window.addEventListener('scroll', onScroll, { passive: true });
          window.addEventListener('resize', onScroll, { passive: true });
          update();
        }
      </script>
    </div>
  </body>
</html>
