---
import BackgroundLoop from '../components/BackgroundLoop.astro';
import Nav from '../components/ui/Nav.astro';
import '../styles/fonts.css';
import '../styles/tokens.css';

const pageTitle = 'Edward Anders';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/CaslonOldFace-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
      }
      body {
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-body);
        color: #f5ecd9;
        background: #f5f2ec;
      }
      main {
        text-align: center;
        padding: 1.5rem 2rem;
        text-shadow: 0 1px 12px rgba(0, 0, 0, 0.55);
      }
      h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: var(--font-size-h1);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 0.5rem;
      }
      p {
        color: #e8dcc4;
        margin: 0;
        font-size: var(--font-size-body);
        line-height: var(--line-height-body);
        opacity: 0.9;
      }
    </style>
  </head>
  <body>
    <BackgroundLoop />
    <Nav />
    <main>
      <h1>{pageTitle}</h1>
      <p>Coming soon.</p>
    </main>
  </body>
</html>
