---
import BackgroundLoop from '../components/BackgroundLoop.astro';
import Nav from '../components/ui/Nav.astro';
import '../styles/fonts.css';
import '../styles/tokens.css';

const pageTitle = 'Edward Anders';

// Per-section vignette/inset overrides. The hero now uses the runner-through-
// fields video with a bottom-anchored vignette (top half cream, bottom half
// painting). About keeps the oil painting with a left-anchored vignette.
// Research reuses the oil painting with the right-anchored vignette that the
// hero used to have, so the page reads as an ABAB rhythm (hero/about share a
// fade band, about/research share the oil painting visually).
const heroBgStyle = [
  '--inset-top: 10vh',
  '--inset-left: 0vw',
  '--inset-right: 0vw',
  '--vignette-shape: ellipse',
  '--vignette-size: 180% 100%',
  '--vignette-cx: 50%',
  '--vignette-cy: 60%',
  '--vignette-core: 15%',
  '--vignette-edge: 50%',
  '--bg-offset-x: 50%',
  '--bg-offset-y: 100%',
  '--bg-shift-y: 80px',
  'opacity: 1',
].join('; ');

const aboutBgStyle = [
  // Mirror the vignette + offset to the left so the painting reveals on the
  // opposite side from the hero. Insets and vignette sizing come from the
  // component defaults.
  '--vignette-cx: 0%',
  '--bg-offset-x: 0%',
  'opacity: 0',
].join('; ');

// Research uses the same oil painting as About. Inset + bg-offset match
// About exactly so the painting layer sits in an identical XY position
// — only the vignette anchor flips (left for About, right for Research)
// and the ellipse widens / core shrinks. With painting positions
// matched, the about→research cross-fade is a pure opacity swap with
// no perceptible horizontal shift in the background.
const researchBgStyle = [
  '--bg-offset-x: 0%',
  '--vignette-size: 110% 180%',
  '--vignette-core: 15%',
  'opacity: 0',
].join('; ');

// Projects uses its own horses video, with the same bottom-anchored vignette
// and box geometry as the hero so the layout mirrors it (top half cream,
// bottom half painting).
const projectsBgStyle = [
  '--inset-top: 10vh',
  '--inset-left: 0vw',
  '--inset-right: 0vw',
  '--vignette-shape: ellipse',
  '--vignette-size: 200% 100%',
  '--vignette-cx: 50%',
  '--vignette-cy: 60%',
  '--vignette-core: 10%',
  '--vignette-edge: 50%',
  '--bg-offset-x: 50%',
  '--bg-offset-y: 100%',
  '--bg-shift-y: 80px',
  'opacity: 0',
].join('; ');

// Contact reuses the horses video and keeps the painting in the SAME visual
// position as Projects (matching inset-top + bg-offset + bg-shift). The
// vignette is a wide, short horizontal-band ellipse so cream fades in both
// at the TOP and at the BOTTOM of the painting, with the bottom band larger
// (cy biased up). The 10vh inset-top also gives a cream rail above the box.
const contactBgStyle = [
  '--inset-top: 10vh',
  '--inset-left: 0vw',
  '--inset-right: 0vw',
  '--vignette-shape: ellipse',
  '--vignette-size: 400% 65%',
  '--vignette-cx: 50%',
  '--vignette-cy: 35%',
  '--vignette-core: 5%',
  '--vignette-edge: 50%',
  '--bg-offset-x: 50%',
  '--bg-offset-y: 100%',
  '--bg-shift-y: 80px',
  'opacity: 0',
].join('; ');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/CaslonOldFace-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 4rem;
        /*
         * Mandatory scroll-snap on each section's top edge — the page
         * always settles at a section boundary so the user doesn't drift
         * mid-transition.
         */
        scroll-snap-type: y mandatory;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
          scroll-snap-type: none;
        }
      }
      body {
        margin: 0;
        font-family: var(--font-body);
        background: #f5f2ec;
        color: #002d1a;
      }
      .section {
        position: relative;
        min-height: 100vh;
        padding: 6rem 2rem 4rem;
        box-sizing: border-box;
        scroll-snap-align: start;
        scroll-snap-stop: always;
      }
      .section h2,
      .fixed-content h2 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1.5rem;
      }
      .section h3,
      .fixed-content h3 {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        margin: 2rem 0 0.75rem;
      }
      .section p,
      .fixed-content p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: 32rem;
        margin: 0 0 1rem;
      }
      .section ul,
      .fixed-content ul {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: 32rem;
        margin: 0 0 1rem;
        padding: 0;
        list-style: none;
      }
      .section ul li,
      .fixed-content ul li {
        margin: 0 0 0.25rem;
      }
      /*
       * Fixed-position content blocks — sit at vertical-centre of the
       * viewport on opposite sides. They do not scroll with the page;
       * they only fade in/out via opacity tied to scroll progress.
       * This keeps the typography visually settled while the background
       * cross-fades between sections.
       */
      .fixed-content {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        max-width: 32rem;
        /*
         * border-box so max-height (and width) include padding — otherwise
         * a large padding-top on the about block would push the element
         * past the bottom of the viewport, making the bottom of the inner
         * scroll unreachable.
         */
        box-sizing: border-box;
        z-index: 10;
        will-change: opacity;
        /*
         * pointer-events default to none; the scroll script toggles them
         * to `auto` when the block becomes visible. Otherwise an invisible
         * fixed block (opacity 0) would still intercept wheel and click
         * events over half the viewport, blocking page scroll.
         */
        pointer-events: none;
      }
      .fixed-content--right {
        right: 2rem;
      }
      /*
       * Inner scroll for any content block with long-form content (about,
       * research, etc). The hero is short and never gets this modifier —
       * keeps it from becoming a wheel-capturing scroll container that
       * could interfere with page scroll.
       */
      .fixed-content--scroll {
        padding-top: 10rem;
        max-height: calc(100vh - 4rem);
        overflow-y: auto;
        overscroll-behavior: contain;
        scrollbar-width: thin;
        scrollbar-color: rgba(0, 45, 26, 0.35) transparent;
      }
      .fixed-content--scroll::-webkit-scrollbar {
        width: 6px;
      }
      .fixed-content--scroll::-webkit-scrollbar-track {
        background: transparent;
      }
      .fixed-content--scroll::-webkit-scrollbar-thumb {
        background: rgba(0, 45, 26, 0.35);
        border-radius: 3px;
      }
      /*
       * Accordion items — native <details>/<summary> with a custom chevron.
       * Hides the browser's default marker, draws a `>` on the left of each
       * summary, and rotates it 90° when the item is open.
       */
      .fixed-content details {
        margin: 0 0 0.5rem;
      }
      .fixed-content summary {
        list-style: none;
        cursor: pointer;
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        user-select: none;
      }
      .fixed-content summary::-webkit-details-marker {
        display: none;
      }
      .fixed-content summary::before {
        content: '›';
        display: inline-block;
        flex-shrink: 0;
        font-weight: 400;
        transform-origin: center 55%;
        transition: transform 180ms ease;
      }
      .fixed-content details[open] summary::before {
        transform: rotate(90deg);
      }
      .fixed-content details > *:not(summary) {
        margin: 0.25rem 0 0.5rem 1.4rem;
        font-size: 0.9rem;
        font-weight: 300;
        line-height: 1.55;
        opacity: 0.82;
      }
      /* Date line inside an accordion — distinct from the description paragraph */
      .fixed-content details .date {
        font-weight: 500;
        opacity: 1;
        margin-bottom: 0.35rem;
      }
      /*
       * Additional subtext inside an accordion — sits between the date and
       * the description. Use for scholarships, honours, sub-titles, etc.
       * Regular weight, full opacity, kept tight against the date above.
       */
      .fixed-content details .additional-subtext {
        font-weight: 400;
        opacity: 1;
        margin-top: -0.15rem;
        margin-bottom: 0.5rem;
      }
      /* Inline text link — used for the CV download at the bottom of about */
      .fixed-content a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 0.2em;
        transition: opacity 180ms ease;
      }
      .fixed-content a:hover {
        opacity: 0.7;
      }
      .fixed-content a:focus-visible {
        outline: 2px solid currentColor;
        outline-offset: 4px;
        border-radius: 2px;
      }
      .fixed-content .cv-download {
        /*
         * Higher specificity than the global `.fixed-content p` rule, so the
         * top margin actually wins. Gives the CV link breathing room from
         * the last accordion above.
         */
        margin: 2rem 0 0;
        font-size: 1rem;
        font-weight: 300;
      }
      .fixed-content--left {
        left: 2rem;
      }
      /*
       * Hero block — overrides .fixed-content / .fixed-content--left so the
       * title sits centred horizontally and anchored closer to the top of
       * the viewport (instead of vertically centred at left). Sits on the
       * cream band above the bottom-anchored hero vignette.
       */
      /*
       * Centred-top text layout — title and body sit horizontally centred,
       * anchored near the top of the viewport. Used by the hero and the
       * Projects section so they share a layout opposite the side-anchored
       * About / Research blocks.
       */
      .fixed-content--centre-top {
        top: 15vh;
        left: 50%;
        right: auto;
        transform: translateX(-50%);
        text-align: center;
        max-width: 40rem;
      }
      /*
       * Mirror of --centre-top — anchored near the BOTTOM of the viewport,
       * for sections whose painting sits at the top and content sits in
       * the cream band below. Used by Contact.
       */
      .fixed-content--centre-bottom {
        top: auto;
        bottom: 3vh;
        left: 50%;
        right: auto;
        transform: translateX(-50%);
        text-align: center;
        max-width: 40rem;
      }
      /*
       * Contact block — email link prominent, three SVG social icons in a
       * row below.
       */
      .contact-email {
        font-family: var(--font-body);
        font-size: 1.25rem;
        font-weight: 300;
        margin: 0 0 2rem;
      }
      .contact-socials {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 1.75rem;
        margin: 0;
      }
      .contact-socials a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        color: inherit;
        text-decoration: none;
        transition: opacity 180ms ease;
      }
      .contact-socials a:hover {
        opacity: 0.65;
      }
      .contact-socials svg {
        width: 1.5rem;
        height: 1.5rem;
        fill: currentColor;
      }
      /* Oxford crest PNG — sized slightly larger so the lettering reads */
      .contact-socials img {
        width: 1.75rem;
        height: 1.75rem;
        object-fit: contain;
      }
      /*
       * Projects block — uses the centre-top positioning (block centred in
       * the viewport) but widens just enough to fit the "Projects" heading
       * + the single project card with a small gap between them.
       */
      .fixed-content--projects {
        max-width: 44rem;
        text-align: left;
      }
      /*
       * Projects layout — two tightly-spaced columns: "Projects" heading
       * on the left, the single project card on the right. Both columns
       * sit centred together in the middle of the viewport.
       */
      .projects-layout {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 2rem;
        align-items: start;
      }
      .projects-title {
        margin: 0;
      }
      .project {
        display: flex;
        flex-direction: column;
        max-width: 28rem;
      }
      @media (max-width: 768px) {
        .projects-layout {
          grid-template-columns: 1fr;
          gap: 2rem;
        }
      }
      /*
       * Project title — sized to match .projects-title (h2) exactly so
       * their glyph tops align on the same baseline when the layout
       * places them in adjacent columns.
       */
      .project h3 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1.5rem;
      }
      .project p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: none;
        margin: 0;
      }
      /*
       * Project link — sits below the description with a small gap.
       * Uses the same underlined inline-link style as .fixed-content a.
       * mt: auto pushes it to the bottom of its column when columns vary
       * in length, so links stay aligned along the row.
       */
      .project .project-link {
        /*
         * Two-class specificity (0,2,0) wins over the global
         * `.fixed-content p` rule (0,1,1), so this top margin actually
         * applies. Increase to widen the gap between description + link.
         */
        margin: 2rem 0 0;
        font-size: 0.95rem;
      }
      .hero h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1rem;
      }
      .hero p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.5;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <BackgroundLoop
      sectionKey="home"
      videoBase="/bg/research-loop"
      posterBase="/bg/research-poster"
      style={heroBgStyle}
    />
    <BackgroundLoop sectionKey="about" style={aboutBgStyle} />
    <BackgroundLoop sectionKey="research" style={researchBgStyle} />
    <BackgroundLoop
      sectionKey="projects"
      videoBase="/bg/projects-loop"
      posterBase="/bg/projects-poster"
      style={projectsBgStyle}
    />
    <BackgroundLoop
      sectionKey="contact"
      videoBase="/bg/projects-loop"
      posterBase="/bg/projects-poster"
      style={contactBgStyle}
    />
    <Nav />

    <!--
      Fixed-position content blocks — sit at vertical-centre of the viewport
      and cross-fade via opacity tied to scroll progress. The empty sections
      below provide scroll length and snap targets for the page.
    -->
    <div class="hero fixed-content fixed-content--centre-top" data-section-content="home">
      <h1>{pageTitle}</h1>
      <p>
        Data Science PhD at the University of
        Oxford researching the political and societal impacts of AI and building the infrastructure for synthetic agents.
      </p>
    </div>

    <div
      class="fixed-content fixed-content--right fixed-content--scroll"
      data-section-content="about"
      style="opacity: 0"
    >
      <h2>About</h2>
      <p>
        Edward is a DPhil candidate in Social Data Science at the Oxford Internet Institute,
        building synthetic electorates to predict political behaviour.
      </p>

      <h3>Education</h3>
      <ul>
        <li>
          <details>
            <summary>DPhil Social Data Science — Jesus College, Oxford</summary>
            <p class="date">2026–</p>
            <p class="additional-subtext">
              Shirley Scholar</p>
            <p>
              <p>Oxford Internet Institute. Using synthetic agent-based models of the Uk electorate to predict political behaviour under different AI-generated treatments.</p>
            </p>
          </details>
          <li>
            <details>
              <summary
                >MPhil Politics — St Antony's College, Oxford</summary
              >
              <p class="date">2024–2026</p>
              <p class="additional-subtext">Dahrendorf Scholar</p>
              <p>
                Papers on advanced experimental, quantitative, and computational social science. Thesis investigated whether labelling
                AI-generated political content mitigates or deepens affective polarisation using survey experiments funded by YouGov.              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>BSc Economics and Politics — University of Bristol</summary>
              <p class="date">2018–2021</p>
              <p>
                1st-Class Honours. Head of School's Commendation for the dissertation and final
                year.
              </p>
            </details>
          </li>
        </li>

        <h3>Experience</h3>
        <ul>
          <li>
            <details>
              <summary>Graduate Researcher — Nuffield College, Oxford</summary>
              <p class="date">2025–</p>
              <p>
                Assisting Professor Rachel Bernhard on her Appearance-Based Politics book project.
                Built PDF scraping and data-extraction pipelines in Python and built reproducible analysis scripts in R.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Research Analyst — Oxford Levant Advisory</summary>
              <p class="date">2025–</p>
              <p>
                Building data solutions for a geopolitical risk consultancy. Developed a pipeline of live news and social media data on the Middle East building an open-source media map.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Strategy Research Manager — Complyance</summary>
              <p class="date">2024–2025</p>
              <p>
                Employee #10 at a seed-stage AI GRC startup. Backed by Creandum. Established a post-sales department with the CSO and CEO. Led cybersecurity research across the EU AI Act, SOC2, ISO 27001, GDPR, and HIPPA for clients to define how forward-deployed engineering teams can deploy AI compliance agents.
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary>Senior Founder's Associate — Compose</summary>
              <p class="date">2021–2024</p>
              <p>
                Employee #1 at a Creandum-backed seed-stage startup building an all-in-one inbox management tool. Led operations and GTM as well as building the data infrastructure and analytics for user behaviour and growth. Hired and managed the first 5 employees across engineering, product, and growth functions.
              </p>
            </details>
          </li>
        </ul>

        <p class="cv-download">
          <a href="/edward-anders-cv.pdf" target="_blank" rel="noopener"
            >Download full curriculum vitae</a
          >
        </p>
      </div>

      <div
        class="fixed-content fixed-content--left fixed-content--scroll"
        data-section-content="research"
        style="opacity: 0"
      >
        <h2>Research</h2>
        <p>
          Research at the intersection of AI and computational social science, investigating the political and societal impacts of AI through large-scale experiments and synthetic agent-based models.
        </p>

        <h3>Publications</h3>
        <ul>
          <li>
            <details>
              <summary>MPhil Thesis: AI Labels and Affective Polarisation</summary>
              <p class="date">Working paper · 2026</p>
              <p>
                Understanding the effects of AI labels as a treatment to mitigate downstream effects of the effects of AI-generated content on trust and emotional-based affective polarisation. Developed a new formal model of the interaction between AI labels, trust, and emotions and tested experimentally with two survey experiments fielded by YouGov.
              </p>
              <p>
                <a href="/edward-anders-mphil-thesis.pdf" target="_blank" rel="noopener"
                  >Download thesis (PDF)</a
                >
              </p>
            </details>
          </li>
          <li>
            <details>
              <summary
                >Talking To Machines: Synthetic Replication Games — Duch, Batistoni et al.</summary
              >
              <p class="date">Forthcoming</p>
              <p class="additional-subtext">PNAS / Nature Computational Science (in preparation)</p>
              <p>
                Co-author on a paper from the Talking to Machines project at Nuffield College,
                Oxford — a platform to facilitate the design, conduct, and analysis of large-scale
                experimental trials using LLM-powered agents.
              </p>
            </details>
          </li>
        </ul>

        <h3>Grants &amp; awards</h3>
        <ul>
          <li>
            <details>
              <summary>Oxford CESS Research Grant</summary>
              <p class="date">2025</p>
              <p>£1,500 from the Centre for Experimental Social Sciences.</p>
            </details>
          </li>
          <li>
            <details>
              <summary>Norman Chester Fund Research Grant</summary>
              <p class="date">2025</p>
              <p>£1,000 awarded for thesis research.</p>
            </details>
          </li>
          <li>
            <details>
              <summary>YouGov UniOM Survey Experiment Grant</summary>
              <p class="date">2024 &amp; 2025</p>
              <p>Awarded twice, ~£1,000 each, to field two nationally representative UK survey experiments.</p>
            </details>
          </li>
        </ul>
      </div>

      <div
        class="fixed-content fixed-content--centre-top fixed-content--projects"
        data-section-content="projects"
        style="opacity: 0"
      >
        <div class="projects-layout">
          <h2 class="projects-title">Projects</h2>
          <article class="project">
            <h3>Simparlia</h3>
            <p>Simulating parliamentarian voting behaviour using digital AI personas of UK MPs.</p>
            <p class="project-link">
              <a href="https://simparlia.com/" target="_blank" rel="noopener">simparlia.com →</a>
            </p>
          </article>
        </div>
      </div>

      <div
        class="fixed-content fixed-content--centre-bottom"
        data-section-content="contact"
        style="opacity: 0"
      >
        <h2>Get in touch</h2>
        <p class="contact-email">
          <a href="mailto:edward.anders@politics.ox.ac.uk">edward.anders@politics.ox.ac.uk</a>
        </p>
        <p class="contact-socials">
          <a href="https://x.com/edwardaw" target="_blank" rel="noopener" aria-label="X (formerly Twitter)">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              />
            </svg>
          </a>
          <a href="https://github.com/eawanders" target="_blank" rel="noopener" aria-label="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.218.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
