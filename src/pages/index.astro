---
import BackgroundLoop from '../components/BackgroundLoop.astro';
import Nav from '../components/ui/Nav.astro';
import '../styles/fonts.css';
import '../styles/tokens.css';

const pageTitle = 'Edward Anders';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="preload"
      href="/fonts/CaslonOldFace-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/fonts/GeistMono-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <title>{pageTitle}</title>
    <style>
      html {
        scroll-behavior: smooth;
        scroll-padding-top: 4rem;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }
      body {
        margin: 0;
        font-family: var(--font-body);
        background: #f5f2ec;
        color: #002d1a;
      }
      .section {
        position: relative;
        min-height: 100vh;
        padding: 6rem 2rem 4rem;
        box-sizing: border-box;
      }
      .section h2 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1.5rem;
      }
      .section p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.6;
        max-width: 32rem;
        margin: 0 0 1rem;
      }
      /*
       * Hero section: title sits at left-middle of the first viewport so it
       * acts as the splash, then scrolls naturally out of view as the user
       * moves to the next section.
       */
      .hero {
        position: absolute;
        top: 50%;
        left: 2rem;
        transform: translateY(-50%);
        max-width: 32rem;
      }
      .hero h1 {
        font-family: var(--font-display);
        font-weight: 400;
        font-size: clamp(2.5rem, 6vw, 5rem);
        line-height: var(--line-height-display);
        letter-spacing: var(--letter-spacing-display);
        margin: 0 0 1rem;
      }
      .hero p {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 300;
        line-height: 1.5;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <BackgroundLoop />
    <Nav />
    <main>
      <section id="top" class="section section-hero">
        <div class="hero">
          <h1>{pageTitle}</h1>
          <p>Researching the political and societal impacts of AI. Data science PhD at the University of Oxford. Building the infrastructure for synthetic agents.</p>
        </div>
      </section>

      <section id="about" class="section">
        <h2>About</h2>
        <p>Placeholder content for the about section. Real bio coming soon.</p>
      </section>

      <section id="research" class="section">
        <h2>Research</h2>
        <p>Placeholder content for the research section. Publications and projects coming soon.</p>
      </section>

      <section id="projects" class="section">
        <h2>Projects</h2>
        <p>Placeholder content for the projects section. Selected work coming soon.</p>
      </section>
    </main>
  </body>
</html>
